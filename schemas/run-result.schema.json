{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run result (executor output, reporter input)",
  "description": "Structured outcome of a single test unit, written by test-executor to artifacts/<run-id>/04-run-<unit_id>/result.json and consumed by linear-reporter. Documented fields are required; additional fields are tolerated for forward compatibility but the validator warns on unknown top-level keys.",
  "type": "object",
  "required": [
    "run_id",
    "unit_id",
    "tickets",
    "env",
    "user_role",
    "verdict",
    "passed_primary",
    "scenarios"
  ],
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_\\d{4}_[A-Z]+-\\d+$",
      "description": "<YYYY-MM-DD>_<HHMM>_<first-ticket-id>"
    },
    "unit_id": {
      "type": "string",
      "pattern": "^unit-\\d+$"
    },
    "tickets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-\\d+$"
      },
      "minItems": 1
    },
    "env": {
      "enum": [
        "prod",
        "stg"
      ]
    },
    "user_role": {
      "enum": [
        "external",
        "internal"
      ]
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "error"
      ]
    },
    "passed_primary": {
      "type": "boolean"
    },
    "case_under_test": {
      "type": "object",
      "description": "The case the executor actually drove. Helps reviewers tell when 'wrong-case' bugs sneak in.",
      "properties": {
        "case_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "observed_state": {
          "type": "string"
        },
        "fixtures_uploaded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at_run_start": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "title",
          "status"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "pattern": "^s?\\d+$"
              }
            ]
          },
          "kind": {
            "enum": [
              "primary",
              "edge",
              "skip"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "skipped_per_spec"
            ]
          },
          "fail_reason": {
            "type": "string",
            "description": "Required when status='fail' (validator enforces). One short sentence; the screenshot below carries the rest."
          },
          "evidence": {
            "type": "object",
            "description": "Free-form structured evidence the reporter may surface. Recommended keys: rect, viewport, header, observed_value, expected_value.",
            "additionalProperties": true
          },
          "screenshot": {
            "type": "string",
            "description": "Path relative to 04-run-<unit_id>/, e.g. 'screenshots/02-extracting.png'."
          },
          "screenshots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "Free-form 2-5 sentence summary the reporter copies verbatim into the comment Summary section."
    },
    "live_update_findings": {
      "type": "array",
      "description": "Side-channel observations from the run that did NOT change a scenario verdict but the reporter must surface as [Warning] bullets so a human can review. Typical shape: 'X should have updated live but the executor only saw it appear after a reload', or 'API returned status N but UI still shows the previous state'. Empty array means no findings.",
      "items": {
        "type": "object",
        "required": [
          "title",
          "observation"
        ],
        "additionalProperties": true,
        "properties": {
          "title": {
            "type": "string",
            "description": "Short headline used as the [Warning] bullet's lead phrase."
          },
          "observation": {
            "type": "string",
            "description": "1-3 sentence description of what was seen vs. what was expected. The reporter copies this nearly verbatim into the comment."
          },
          "where": {
            "type": "string",
            "description": "Which scenario or which point in the run produced this side-channel observation, e.g. 'during scenario 4, after click close, before reload'."
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "description": "Optional \u2014 defaults to medium if absent. Reporter keeps the order Warning>Spec>Env>Info regardless."
          }
        }
      }
    },
    "screenshot_picks_for_comment": {
      "type": "array",
      "description": "Optional explicit list of (scenario, source PNG, caption) the reporter should attach in the comment's Evidence section. If omitted, reporter falls back to picking the screenshot field from each scenario.",
      "items": {
        "type": "object",
        "required": [
          "scenario",
          "title",
          "caption",
          "source"
        ],
        "additionalProperties": true,
        "properties": {
          "scenario": {
            "type": "string",
            "pattern": "^s\\d+$"
          },
          "verdict": {
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "title": {
            "type": "string"
          },
          "caption": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "description": "Path relative to 04-run-<unit_id>/"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "If a scenario is fail, fail_reason must be present.",
      "type": "object",
      "properties": {
        "scenarios": {
          "type": "array",
          "items": {
            "if": {
              "properties": {
                "status": {
                  "const": "fail"
                }
              }
            },
            "then": {
              "required": [
                "fail_reason"
              ]
            }
          }
        }
      }
    },
    {
      "description": "verdict='pass' implies passed_primary=true.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        }
      },
      "then": {
        "properties": {
          "passed_primary": {
            "const": true
          }
        }
      }
    }
  ]
}